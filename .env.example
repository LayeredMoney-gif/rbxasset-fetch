# Your .ROBLOSECURITY cookie from Roblox
# Get it from browser DevTools > Application > Cookies > .ROBLOSECURITY
ROBLOX_COOKIE=your_cookie_here

# Local-only by default. Use 0.0.0.0 only if you intend LAN exposure.
HOST=127.0.0.1
PORT=3000

# Cache fetched assets for 5 minutes to avoid duplicate CDN/API requests.
ASSET_CACHE_TTL_MS=300000

# Set true only if you explicitly want clients to pass X-Roblox-Cookie.
ALLOW_HEADER_COOKIE=false
